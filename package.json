{
  "name": "nft-airdrop-platform",
  "version": "1.0.0",
  "private": true,
  "description": "NFT Airdrop Platform — Node.js API, Next.js UI, Solidity contracts",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "node --watch server.js",
    "dev:web": "cd frontend && next dev -p 3000",
    "start:api": "node server.js",
    "build:web": "cd frontend && next build",
    "start:web": "cd frontend && next start -p 3000",
    "clean:web": "node -e \"require('fs').rmSync('frontend/.next',{recursive:true,force:true})\"",
    "db:init": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "contract:compile": "hardhat compile --config contract/hardhat.config.cjs",
    "contract:test": "hardhat test --config contract/hardhat.config.cjs",
    "contract:deploy": "hardhat run contract/scripts/deploy.cjs --config contract/hardhat.config.cjs",
    "contract:node": "hardhat node --config contract/hardhat.config.cjs",
    "lint": "echo \"No linter configured\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.8",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.5",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.4",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "keccak256": "^1.0.6",
    "merkletreejs": "^0.4.1",
    "multer": "^1.4.5-lts.1",
    "next": "^14.2.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "siwe": "^2.3.2",
    "uuid": "^11.0.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@svgr/webpack": "^8.1.0",
    "autoprefixer": "^10.4.20",
    "chai": "^4.5.0",
    "hardhat": "^2.22.17",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
